# Docker Compose Environment Variables
# Copy this file to .env if you need to customize settings

# Service Ports
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Service Bind Addresses
# Use 0.0.0.0 for services that should be reachable from other machines.
FRONTEND_BIND=0.0.0.0
BACKEND_BIND=0.0.0.0

# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Backend Configuration
PYTHONUNBUFFERED=1

# Frontend Configuration
# Leave blank to let browsers call http(s)://<frontend-host>:BACKEND_PORT.
# Set this when the public backend URL is different, for example https://api.example.com.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_PORT=8000
NODE_ENV=production

# Backend CORS
# For a server, set this to the public frontend origin, for example http://203.0.113.10:3000.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
