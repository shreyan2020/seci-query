# Docker Compose Environment Variables
# Copy this file to .env if you need to customize settings

# Service Ports
NGINX_PORT=80

# Service Bind Addresses
# Nginx is the public entrypoint. Frontend/backend stay internal to Docker.
NGINX_BIND=0.0.0.0

# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Backend Configuration
PYTHONUNBUFFERED=1

# Frontend Configuration
# "/" keeps browser API calls on the same origin through nginx.
# Set a full URL only when the public API host differs from the frontend host.
NEXT_PUBLIC_API_URL=/
NEXT_PUBLIC_API_PORT=
NODE_ENV=production

# Backend CORS
# For a server, set this to the public nginx origin, for example http://203.0.113.10 or https://app.example.com.
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000
