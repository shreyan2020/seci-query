{
  "suite_name": "local_smoke",
  "description": "Fast smoke suite over tiny local fixtures for retrieval augmentation and ontology extraction metrics.",
  "tasks": [
    {
      "id": "beir_tiny_retrieval",
      "type": "retrieval_beir",
      "enabled": true,
      "standard_benchmark": "BEIR-style smoke fixture",
      "benchmark": "beir",
      "data_dir": "evals/fixtures/beir_tiny",
      "augmentation_file": "evals/fixtures/beir_tiny/ontology_augmentation.json",
      "name": "beir_tiny",
      "modes": "baseline,ontology",
      "top_k": 20,
      "metric_k": 10
    },
    {
      "id": "extraction_tiny",
      "type": "extraction_jsonl",
      "enabled": true,
      "standard_benchmark": "Normalized biomedical extraction smoke fixture",
      "gold": "evals/fixtures/extraction_tiny/gold.jsonl",
      "predictions": "evals/fixtures/extraction_tiny/predictions.jsonl",
      "name": "extraction_tiny"
    }
  ]
}
